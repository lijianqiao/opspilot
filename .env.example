# =============================================================================
# OpsPilot 环境变量模板
#
# 两种使用场景（不要混用同一份 .env 里的 DSN 主机名）：
#   1) 宿主机开发：cp .env.example .env，uv run / pytest（连 localhost:端口）
#   2) Docker Compose：cp .env.example infra/.env，在 infra/ 下 docker compose up
#      （compose 会读 infra/.env；容器内 DSN 用服务名 postgres，见下方说明）
# =============================================================================

# ---- LLM Server（三选一）----

# 方案 A：Cloud 云端大模型（推荐，无需 GPU）
# DeepSeek
# OPSPILOT_LLM_BASE_URL=https://api.deepseek.com
# OPSPILOT_LLM_MODEL=deepseek-v4-pro
# OPSPILOT_LLM_API_KEY=sk-your-deepseek-api-key

# OpenAI
# OPSPILOT_LLM_BASE_URL=https://api.openai.com/v1
# OPSPILOT_LLM_MODEL=gpt-4o-mini
# OPSPILOT_LLM_API_KEY=sk-your-openai-api-key

# 硅基流动 (SiliconFlow)
# OPSPILOT_LLM_BASE_URL=https://api.siliconflow.cn/v1
# OPSPILOT_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# OPSPILOT_LLM_API_KEY=sk-your-siliconflow-api-key

# 方案 B：VMware 虚拟机 → Windows 宿主机 llama.cpp
# OPSPILOT_LLM_BASE_URL=http://192.168.x.x:8080/v1     # 替换为 Windows 宿主机 IP
# OPSPILOT_LLM_MODEL=qwen3.5-9b
# OPSPILOT_LLM_API_KEY=sk-local

# 方案 C：虚拟机本地 llama.cpp
OPSPILOT_LLM_BASE_URL=http://host.docker.internal:8080/v1
OPSPILOT_LLM_MODEL=qwen3.5-9b
OPSPILOT_LLM_API_KEY=sk-local

# ---- Feishu Bot（启用飞书 WS / 卡片回调时必填）----
OPSPILOT_FEISHU_APP_ID=
OPSPILOT_FEISHU_APP_SECRET=
# 事件验签（未配置则无法安全接收飞书回调）
OPSPILOT_FEISHU_VERIFICATION_TOKEN=
# 启用消息加密时必填；未启用加密可留空
OPSPILOT_FEISHU_ENCRYPT_KEY=

# ---- 安全与鉴权（生产对外服务时必填，fail-closed）----
# HTTP API /ask、/alert：Authorization: Bearer <token>；为空时端点返回 503
OPSPILOT_API_AUTH_TOKEN=
# Alertmanager Webhook：X-OpsPilot-Signature（HMAC-SHA256 body）；为空时返回 503
OPSPILOT_ALERTMANAGER_HMAC_SECRET=
# 危险操作人工确认 pending 的 TTL（秒）
OPSPILOT_CONFIRM_TTL_SECONDS=300
# 操作审计 JSONL 路径（append-only）
OPSPILOT_AUDIT_LOG_PATH=logs/opspilot_audit.jsonl

# ---- Docker Compose 基础设施（写入 infra/.env，供 compose 变量替换）----
# 原则：镜像版本、服务名、depends_on 留在 infra/docker-compose.yml；
#       会变的（密码、宿主机映射端口、LLM）放 .env，避免 compose 与文档两处维护。
#
# Postgres 容器凭据（与 compose 中 postgres 服务联动，改密码须同步 OPSPILOT_PG_DSN_*）
POSTGRES_USER=opspilot
POSTGRES_PASSWORD=opspilot
POSTGRES_DB=opspilot
# 宿主机映射端口（仅当本机 5432 冲突时改 compose 与这里）
POSTGRES_HOST_PORT=5432

# 宿主机 / CLI / pytest 用（主机名 localhost）
OPSPILOT_PG_DSN=postgresql://opspilot:opspilot@localhost:5432/opspilot
# 容器内 agent-core 用（主机名 postgres，由 compose 注入，勿在宿主机 .env 里当默认）
# OPSPILOT_PG_DSN_CONTAINER=postgresql://opspilot:opspilot@postgres:5432/opspilot

# 依赖服务宿主机端口（代码默认连 localhost；仅文档/排障参考，与 compose ports 对齐）
# QDRANT_HOST_PORT=6333
# REDIS_HOST_PORT=6379
# AGENT_HTTP_PORT=8000
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000
# Grafana 本地演示默认 admin/admin（在 compose 中写死即可，生产应改 compose 或 secrets）

# ---- LLM Gateway（宿主机运行 opspilot-gateway 时使用）----
# /v1/chat/completions Bearer 鉴权；为空时返回 503（避免开放代理）
OPSPILOT_GATEWAY_AUTH_TOKEN=
OPSPILOT_GATEWAY_PROVIDERS=[{"name":"local","base_url":"http://localhost:8080/v1","api_key":"sk-local"}]
OPSPILOT_GATEWAY_REDIS_URL=redis://localhost:6379/0
OPSPILOT_GATEWAY_REQUESTS_PER_MINUTE=60
OPSPILOT_GATEWAY_PROVIDER_TIMEOUT_SECONDS=120
